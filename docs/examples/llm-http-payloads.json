      "error": {
        "code": "ERR_LLM_REFRESH_UNSUPPORTED",
        "message": "provider nao suporta refresh"
      }
    }
  },
  "responses": {
    "request": {
      "method": "POST",
      "path": "/v1/projects/pockettrace/llm/responses",
      "body": {
        "providerId": "openai",
        "profileId": "default",
        "model": "gpt-5.6-sol",
        "instructions": "Responda de forma objetiva.",
        "input": [
          { "role": "user", "content": "Responda apenas: ok" }
        ],
        "stream": true,
        "store": false,
        "intelligence": "thinking",
        "serviceTier": "priority",
        "reasoning": {
          "effort": "medium",
          "summary": "auto"
        },
        "outputContract": {
          "id": "pockettrace.AIValidatedEnrichment.v1",
          "schemaHash": "sha256:43d728077867a5329320fcfff2f07b4426097d99fb7b6c6adde5178f71ec1060",
          "strict": true,
          "jsonSchema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "type": "object",
            "properties": {
              "summary": { "type": "string" }
            },
            "required": ["summary"],
            "additionalProperties": false
          }
        }
      }
    },
    "response": {
      "events": [
        {
          "type": "response.output_text.delta",
          "payload": "{\"type\":\"response.output_text.delta\",\"delta\":\"{\\\"summary\\\":\\\"ok\\\"}\"}"
        },
        { "type": "done" }
      ],
      "responseId": "resp_123",
      "usage": {
        "inputTokens": 10,
        "outputTokens": 1,
        "totalTokens": 11
      },
      "outputText": "{\"summary\":\"ok\"}"
    }
  },
  "errors": {
    "providerUnknown": {
      "httpStatus": 400,
      "response": { "error": { "code": "ERR_LLM_PROVIDER_UNKNOWN", "message": "provider LLM desconhecido" } }
    },
    "authRequired": {
      "httpStatus": 401,
      "response": { "error": { "code": "ERR_LLM_AUTH_REQUIRED", "message": "autenticacao do provider necessaria" } }
    },
    "authExpired": {
      "httpStatus": 401,
      "response": { "error": { "code": "ERR_LLM_AUTH_EXPIRED", "message": "credencial expirada ou invalida" } }
    },
    "refreshUnsupported": {
      "httpStatus": 400,
      "response": { "error": { "code": "ERR_LLM_REFRESH_UNSUPPORTED", "message": "provider nao suporta refresh" } }
    },
    "requestInvalid": {
      "httpStatus": 400,
      "response": { "error": { "code": "ERR_LLM_REQUEST_INVALID", "message": "request LLM invalido" } }
    },
    "outputContractUnsupported": {
      "httpStatus": 422,
      "response": { "error": { "code": "ERR_LLM_OUTPUT_CONTRACT_UNSUPPORTED", "message": "provider ou modelo nao suporta outputContract" } }
    },
    "providerUnavailable": {
      "httpStatus": 502,
      "httpStatuses": [408, 502, 504],
      "response": { "error": { "code": "ERR_LLM_PROVIDER_UNAVAILABLE", "message": "provider LLM indisponivel" } }
    },
    "rateLimited": {
      "httpStatus": 429,
      "response": { "error": { "code": "ERR_LLM_RATE_LIMITED", "message": "provider aplicou rate limit" } }
    },
    "responseEmpty": {
      "httpStatus": 502,
      "response": { "error": { "code": "ERR_LLM_RESPONSE_EMPTY", "message": "provider retornou resposta vazia" } }
    },
    "internal": {
      "httpStatus": 500,
      "response": { "error": { "code": "ERR_LLM_INTERNAL", "message": "erro interno" } }
    }
  },
  "mcp": {
    "responseRule": "result.content[0].text contem o JSON do mesmo contrato HTTP",
    "tools": {
      "llm_providers": {
