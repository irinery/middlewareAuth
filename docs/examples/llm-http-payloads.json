  "fieldPolicy": {
    "stable": [
      "contractVersion",
      "providerId",
      "projectId",
      "profileId",
      "authenticated",
      "status",
      "loginSessionId",
      "events",
      "responseId",
      "usage",
      "outputText",
      "outputContract.id",
      "outputContract.schemaHash",
      "outputContract.strict",
      "outputContract.jsonSchema",
      "error.code",
      "error.message"
    ],
    "providerSpecificValues": [
      "providers[].models[].id",
      "providers[].auth.modes[]",
      "providers[].auth.fields[]",
      "authFields",
      "model",
      "accountId",
      "baseUrl",
      "email",
      "planType",
      "extra"
    ],
    "reservedMetadataContainer": "metadata",
    "unknownTopLevelResponseFields": "ignore"
  },
